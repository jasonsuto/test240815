# JitPack runs install-to-m2.sh on Linux; CRLF breaks `set` (e.g. "pipefail: invalid option name").
delivery/jitpack/*.sh text eol=lf
delivery/jitpack/maven-coordinates.properties text eol=lf

# Gradle wrapper must be LF on Linux or the shebang can break with "No such file or directory".
gradlew text eol=lf
